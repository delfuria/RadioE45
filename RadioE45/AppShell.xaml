<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RadioE45.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RadioE45.Views"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent
            Title="In Onda"
            Icon="tab_onair.png"
            ContentTemplate="{DataTemplate views:OnAirPage}"
            Route="OnAirPage" />
        <ShellContent
            Title="Canali Radio"
            Icon="tab_radiolist.png"
            ContentTemplate="{DataTemplate views:RadioListPage}"
            Route="RadioListPage" />
        <ShellContent
            Title="Palinsesto"
            Icon="tab_schedule.png"
            ContentTemplate="{DataTemplate views:SchedulePage}"
            Route="SchedulePage" />
        <ShellContent
            Title="Impostazioni"
            Icon="tab_settings.png"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
