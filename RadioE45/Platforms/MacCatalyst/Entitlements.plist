<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox: obbligatorio per Mac Catalyst (App Store e Developer ID) -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Connessioni di rete in uscita (streaming radio) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Hardened Runtime: il runtime .NET richiede compilazione JIT -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Hardened Runtime: il runtime .NET scrive in memoria eseguibile -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
