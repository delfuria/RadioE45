<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{DynamicResource PageBackground}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{DynamicResource TabBarBackground}" />
        <Setter Property="Shell.ForegroundColor" Value="{DynamicResource PrimaryText}" />
        <Setter Property="Shell.TitleColor" Value="{DynamicResource PrimaryText}" />
        <Setter Property="Shell.DisabledColor" Value="{DynamicResource MutedText}" />
        <Setter Property="Shell.UnselectedColor" Value="{DynamicResource MutedText}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{DynamicResource TabBarBackground}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{DynamicResource Accent}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{DynamicResource MutedText}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{DynamicResource PrimaryText}" />
    </Style>

    <Style TargetType="Label" x:Key="HeadlineLabel">
        <Setter Property="TextColor" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="SubtitleLabel">
        <Setter Property="TextColor" Value="{DynamicResource SecondaryText}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="CaptionLabel">
        <Setter Property="TextColor" Value="{DynamicResource MutedText}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="LiveBadgeLabel">
        <Setter Property="TextColor" Value="{StaticResource LiveRed}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Button" x:Key="PlayButton">
        <Setter Property="BackgroundColor" Value="{DynamicResource Accent}" />
        <Setter Property="TextColor" Value="{DynamicResource PrimaryText}" />
        <Setter Property="CornerRadius" Value="40" />
        <Setter Property="HeightRequest" Value="80" />
        <Setter Property="WidthRequest" Value="80" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{DynamicResource Accent}" />
        <Setter Property="MaximumTrackColor" Value="{DynamicResource CardElevated}" />
        <Setter Property="ThumbColor" Value="{DynamicResource PrimaryText}" />
    </Style>

    <Style TargetType="Border" x:Key="CardBorder">
        <Setter Property="BackgroundColor" Value="{DynamicResource CardBackground}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Stroke" Value="{DynamicResource CardElevated}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{DynamicResource Accent}" />
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{DynamicResource Accent}" />
        <Setter Property="Background" Value="{DynamicResource PageBackground}" />
    </Style>

</ResourceDictionary>
