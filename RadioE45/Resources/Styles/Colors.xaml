<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Dark theme raw colors -->
    <Color x:Key="BackgroundDark">#0D0D0D</Color>
    <Color x:Key="SurfaceDark">#1A1A1A</Color>
    <Color x:Key="SurfaceElevatedDark">#2A2A2A</Color>
    <Color x:Key="AccentPrimary">#E63946</Color>
    <Color x:Key="AccentSecondary">#457B9D</Color>
    <Color x:Key="TextPrimary">#F1FAEE</Color>
    <Color x:Key="TextSecondary">#A8DADC</Color>
    <Color x:Key="TextMuted">#6B7280</Color>
    <Color x:Key="LiveRed">#FF3B30</Color>

    <!-- Light theme raw colors -->
    <Color x:Key="BackgroundLight">#F8F9FA</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceElevatedLight">#F0F0F0</Color>
    <Color x:Key="TextPrimaryLight">#1A1A1A</Color>
    <Color x:Key="TextSecondaryLight">#457B9D</Color>
    <Color x:Key="TextMutedLight">#9CA3AF</Color>

    <!-- Semantic colors (dark defaults) — swapped at runtime by ThemeService via DynamicResource -->
    <Color x:Key="PageBackground">#0D0D0D</Color>
    <Color x:Key="CardBackground">#1A1A1A</Color>
    <Color x:Key="CardElevated">#2A2A2A</Color>
    <Color x:Key="PrimaryText">#F1FAEE</Color>
    <Color x:Key="SecondaryText">#A8DADC</Color>
    <Color x:Key="MutedText">#6B7280</Color>
    <Color x:Key="Accent">#E63946</Color>
    <Color x:Key="AccentBlue">#457B9D</Color>
    <Color x:Key="TabBarBackground">#111111</Color>
    <Color x:Key="DividerColor">#2A2A2A</Color>

</ResourceDictionary>
