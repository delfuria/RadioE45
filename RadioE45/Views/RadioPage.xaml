<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RadioE45.Views.RadioPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RadioE45.Views"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="RadioPage">
    <ContentPage.Background>
        <LinearGradientBrush>

            <GradientStop x:Name="FirstColor" Offset="0.0" Color="#552586" />

            <GradientStop x:Name="SecondColor" Offset="1.0" Color="#B589D6" />

        </LinearGradientBrush>
    </ContentPage.Background>
    <VerticalStackLayout Padding="20" Spacing="20">

        <Label
            x:Name="RadioName"
            FontAttributes="Bold"
            FontSize="34"
            HorizontalOptions="Center">
            <Label.Shadow>
                <Shadow
                    Brush="Black"
                    Opacity="0.6"
                    Radius="10"
                    Offset="5,5" />
            </Label.Shadow>
        </Label>


            <Image
                x:Name="RadioImage"
                Margin="20"
                Aspect="AspectFit"
                HorizontalOptions="Center"
                MaximumHeightRequest="{OnPlatform Android=250,
                                                  iOS=250,
                                                  WinUI=300,
                                                  MacCatalyst=300}"
                MaximumWidthRequest="{OnPlatform Android=250,
                                                 iOS=250,
                                                 WinUI=300,
                                                 MacCatalyst=300}"
                Source="kan_88.png"
                VerticalOptions="Center">
                <Image.Shadow>
                    <Shadow
                        Brush="Black"
                        Opacity="0.9"
                        Radius="10"
                        Offset="5,5" />
                </Image.Shadow>
            </Image>




        <local:AudioVisualizerView
            x:Name="AudioVisualizer"
            HeightRequest="20"
            WidthRequest="300" />

        <!-- Now Playing Card -->
        <Border
            Padding="12"
            BackgroundColor="#33000000"
            HorizontalOptions="Fill"
            StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>
            <Grid
                ColumnDefinitions="80,*"
                ColumnSpacing="12"
                RowDefinitions="Auto,Auto,Auto"
                RowSpacing="5">

                <!--  Album Art  -->
                <Border
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    HeightRequest="80"
                    StrokeThickness="0"
                    WidthRequest="80">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Image
                        x:Name="NowPlayingArt"
                        Aspect="AspectFill"
                        Source="iconblank.png" />
                </Border>

                <!--  Title  -->
                <Label
                    x:Name="NowPlayingTitle"
                    Grid.Row="0"
                    Grid.Column="1"
                    FontAttributes="Bold"
                    FontSize="16"
                    LineBreakMode="TailTruncation"
                    Text="--"
                    TextColor="White"
                    VerticalOptions="End" />

                <!--  Artist  -->
                <Label
                    x:Name="NowPlayingArtist"
                    Grid.Row="1"
                    Grid.Column="1"
                    FontSize="13"
                    LineBreakMode="TailTruncation"
                    Text="--"
                    TextColor="#CCFFFFFF"
                    VerticalOptions="Start" />

                <!--  Progress row  -->
                <Grid
                    Grid.Row="2"
                    Grid.Column="1"
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="6">
                    <Label
                        x:Name="NowPlayingElapsed"
                        FontSize="11"
                        Text="00:00"
                        TextColor="#AAFFFFFF"
                        VerticalOptions="Center" />
                    <ProgressBar
                        x:Name="NowPlayingProgress"
                        Grid.Column="1"
                        BackgroundColor="#44FFFFFF"
                        Progress="0"
                        ProgressColor="White"
                        VerticalOptions="Center" />
                    <Label
                        x:Name="NowPlayingDuration"
                        Grid.Column="2"
                        FontSize="11"
                        Text="00:00"
                        TextColor="#AAFFFFFF"
                        VerticalOptions="Center" />
                </Grid>

            </Grid>
        </Border>

        <HorizontalStackLayout
            Padding="10"
            HorizontalOptions="Center"
            Spacing="20">

            <ImageButton
                x:Name="MediaActionButton"
                BackgroundColor="Transparent"
                Clicked="MediaAction_Clicked"
                HeightRequest="{OnPlatform Android=80,
                                           iOS=90,
                                           WinUI=100,
                                           MacCatalyst=100}"
                HorizontalOptions="Center"
                Source="pause_icon.png"
                VerticalOptions="End"
                WidthRequest="{OnPlatform Android=80,
                                          iOS=90,
                                          WinUI=100,
                                          MacCatalyst=100}" />

            <ImageButton
                BackgroundColor="Transparent"
                Clicked="SkipToEnd_Clicked"
                HeightRequest="{OnPlatform Android=80,
                                           iOS=90,
                                           WinUI=100,
                                           MacCatalyst=100}"
                HorizontalOptions="Center"
                Source="skip_icon.png"
                VerticalOptions="End"
                WidthRequest="{OnPlatform Android=80,
                                          iOS=90,
                                          WinUI=100,
                                          MacCatalyst=100}" />
        </HorizontalStackLayout>


        <toolkit:MediaElement
            x:Name="MediaPlayer"
            HeightRequest="300"
            HorizontalOptions="Center"
            IsVisible="False"
            ShouldAutoPlay="True"
            VerticalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>